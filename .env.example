# GuideAnts backend
GUIDEANTS_BASE_URL=http://localhost:5107
GUIDEANTS_PUB_ID=00000000-0000-0000-0000-000000000000
GUIDEANTS_API_KEY=anonymous
GUIDEANTS_MODEL=guide

# Voice receptionist behavior
WELCOME_GREETING=Thanks for calling! How can I help you today?

# Optional: validate X-Twilio-Signature on incoming requests
TWILIO_AUTH_TOKEN=

# Server
PORT=8080

# Selective barge-in (optional; sensible defaults if unset)
# Seconds to wait after a caller interrupt before auto-resuming (noise/silence)
#BARGE_IN_RESUME_TIMEOUT_S=2.5
# Extra comma-separated phrases (beyond the built-in list) that should stop the reply
#BARGE_IN_EXTRA_STOP_PHRASES=cancel that,forget it
