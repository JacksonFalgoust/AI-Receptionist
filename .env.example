# GuideAnts backend
GUIDEANTS_BASE_URL=http://localhost:5107
GUIDEANTS_PUB_ID=00000000-0000-0000-0000-000000000000
GUIDEANTS_API_KEY=anonymous
GUIDEANTS_MODEL=guide

# Request timeout (seconds) for calls to GuideAnts. The openai SDK's default
# (600s, 2 retries) is dead air on a live phone call, so this app uses a much
# tighter budget and a single retry.
#GUIDEANTS_TIMEOUT_SECONDS=30

# Voice receptionist behavior
WELCOME_GREETING=Thanks for calling! How can I help you today?

# Optional: validate X-Twilio-Signature on incoming requests
TWILIO_AUTH_TOKEN=

# Server
PORT=8080

# Filler phrases (optional; sensible built-in defaults if unset).
# Spoken before the real answer when the caller's utterance looks like a
# question/request, to mask GuideAnts lookup latency. Pipe-separated since
# phrases contain commas/periods.
#FILLER_PHRASES=Let me look that up for you.|One moment while I check on that.

# How long (in seconds) to wait for GuideAnts' reply before speaking a filler
# phrase, for utterances that look like a question/request. If the reply
# arrives before this elapses, no filler is spoken at all.
#FILLER_DELAY_SECONDS=1.0

# Extra comma-separated phrases (beyond the built-in list) that count as pure
# acknowledgment/backchannel noise and should never get a guide reply.
#EXTRA_BACKCHANNEL_PHRASES=no worries,all good

# Extra comma-separated phrases (beyond the built-in barge_in.STOP_PHRASES)
# that, if heard while the assistant is mid-reply, cancel it.
#EXTRA_STOP_PHRASES=cancel that,forget it

# Short local acknowledgments (optional; sensible built-in defaults if unset).
# Spoken instead of a GuideAnts reply when a stop/wait phrase cancels an
# in-flight reply. Pipe-separated since phrases contain periods.
#STOP_ACK_PHRASES=Okay.|Got it.

# Assumed TTS speaking rate in words/second, used to estimate how long a
# reply takes to speak aloud. Twilio's agent-stopped speaker event is the
# primary "reply finished playing" signal; this estimate paces replies until
# the first such event is recognized on a call, and caps how long the app
# waits for one after that.
#TTS_WORDS_PER_SECOND=2.5
